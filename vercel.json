{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(css|js)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    }
  ],
  "redirects": [
    { "source": "/about", "destination": "/heritage", "permanent": true },
    { "source": "/shop", "destination": "/collection", "permanent": true },
    { "source": "/products", "destination": "/collection", "permanent": true },
    { "source": "/faq", "destination": "/journal#faq", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home-1", "destination": "/", "permanent": true },
    { "source": "/terms-conditions", "destination": "/heritage#terms", "permanent": true },
    { "source": "/shipping-returns", "destination": "/heritage#shipping", "permanent": true }
  ]
}
